---
import '../styles/index.css';
import BarraLateral from '../components/BarraLateral.astro';
import BarraSuperior from '../components/BarraSuperior.astro';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Moneycount — Panel General</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;700;800&family=Geist+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="aplicacion">
      <BarraLateral />
      <BarraSuperior />
      <main class="contenido-principal">
        <slot />
      </main>
    </div>
  </body>
</html>
