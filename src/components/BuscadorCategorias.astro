<div class="buscador-categorias">
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="buscador-categorias__icono">
    <circle cx="11" cy="11" r="8" />
    <line x1="21" y1="21" x2="16.65" y2="16.65" />
  </svg>
  <input class="buscador-categorias__input" type="text" placeholder="Buscar categorías..." id="buscador-categorias" />
</div>

<style>
  .buscador-categorias {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--color-border);
    width: 260px;
    transition: border-color 0.15s ease;
  }

  .buscador-categorias:focus-within {
    border-color: var(--color-primary);
  }

  .buscador-categorias__icono {
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .buscador-categorias__input {
    background: transparent;
    border: none;
    font-family: var(--font-geist);
    font-weight: var(--font-weight-regular);
    font-size: 0.8125rem;
    color: var(--color-text);
    width: 100%;
    outline: none;
  }

  .buscador-categorias__input::placeholder {
    color: var(--color-text-muted);
  }
</style>

<script>
  const input = document.getElementById('buscador-categorias');
  if (input) {
    input.addEventListener('input', () => {
      const term = input.value.toLowerCase();
      const cards = document.querySelectorAll('.tarjeta-categoria');
      cards.forEach((card) => {
        const name = card.getAttribute('data-name')?.toLowerCase() || '';
        card.style.display = name.includes(term) ? '' : 'none';
      });
    });
  }
</script>
