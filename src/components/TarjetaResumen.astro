---
export interface Props {
  etiqueta: string;
  valor: string;
  variante: 'fixed' | 'variable' | 'total';
}

const { etiqueta, valor, variante } = Astro.props;
---

<div class:list={['tarjeta-resumen', { 'tarjeta-resumen--total': variante === 'total' }]}>
  <span class="tarjeta-resumen__etiqueta">{etiqueta}</span>
  <span class:list={['tarjeta-resumen__valor', `tarjeta-resumen__valor--${variante}`]}>
    {valor}
  </span>
</div>
