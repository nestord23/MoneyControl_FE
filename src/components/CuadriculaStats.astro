---
import TarjetaStats from './TarjetaStats.astro';

const tarjetas = [
  { titulo: 'Ingresos', valor: '+$48,250.00', variante: 'secondary', icono: 'trending-up' as const },
  { titulo: 'Gastos', valor: '-$32,180.00', variante: 'alert', icono: 'trending-down' as const },
  { titulo: 'Ratio', valor: '1.50', variante: 'primary', icono: 'activity' as const },
  { titulo: 'Prestamos Pendientes', valor: '$12,400.00', variante: 'alert', icono: 'dollar-sign' as const },
];
---

<div class="cuadricula-stats">
  {tarjetas.map((t) => (
    <TarjetaStats titulo={t.titulo} valor={t.valor} variante={t.variante} icono={t.icono} />
  ))}
</div>
