---
export interface Props {
  etiqueta: string;
  valor: string;
  variacion: string;
  positiva: boolean;
}

const { etiqueta, valor, variacion, positiva } = Astro.props;
---

<div class="metrica-mini">
  <span class="metrica-mini__etiqueta">{etiqueta}</span>
  <span class="metrica-mini__valor">{valor}</span>
  <span class:list={['metrica-mini__variacion', `metrica-mini__variacion--${positiva ? 'positiva' : 'negativa'}`]}>
    {variacion}
  </span>
</div>
