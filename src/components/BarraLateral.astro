---
const rutaActual = Astro.url.pathname;

const enlaces = [
  { icono: 'dashboard', label: 'Panel General', href: '/' },
  { icono: 'trending-up', label: 'Ingresos', href: '/ingresos' },
  { icono: 'receipt', label: 'Gastos', href: '/gastos' },
  { icono: 'credit-card', label: 'Préstamos', href: '/prestamos' },
  { icono: 'layout-grid', label: 'Categorías', href: '/categorias' },
  { icono: 'settings', label: 'Ajustes', href: '/ajustes' },
];
---

<aside class="barra-lateral">
  <div class="barra-lateral__logo">
    <svg class="barra-lateral__logo-icono" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10" />
      <polyline points="12 6 12 12 16 14" />
    </svg>
    Moneycount
  </div>

  <nav class="barra-lateral__nav">
    {enlaces.map((enlace) => (
      <a
        href={enlace.href}
        class:list={['barra-lateral__enlace', { 'barra-lateral__enlace--activo': rutaActual === enlace.href }]}
      >
        <svg class="barra-lateral__enlace-icono" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          {enlace.icono === 'dashboard' && (
            <>
              <rect x="3" y="3" width="7" height="7" />
              <rect x="14" y="3" width="7" height="7" />
              <rect x="3" y="14" width="7" height="7" />
              <rect x="14" y="14" width="7" height="7" />
            </>
          )}
          {enlace.icono === 'trending-up' && (
            <>
              <polyline points="23 6 13.5 15.5 8.5 10.5 1 18" />
              <polyline points="17 6 23 6 23 12" />
            </>
          )}
          {enlace.icono === 'receipt' && (
            <>
              <path d="M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1-2-1Z" />
              <path d="M8 7h8" />
              <path d="M8 11h6" />
              <path d="M8 15h4" />
            </>
          )}
          {enlace.icono === 'credit-card' && (
            <>
              <rect x="1" y="4" width="22" height="16" rx="2" ry="2" />
              <line x1="1" y1="10" x2="23" y2="10" />
              <path d="M7 15h4" />
            </>
          )}
          {enlace.icono === 'layout-grid' && (
            <>
              <rect x="3" y="3" width="7" height="7" />
              <rect x="14" y="3" width="7" height="7" />
              <rect x="3" y="14" width="7" height="7" />
              <rect x="14" y="14" width="7" height="7" />
            </>
          )}
          {enlace.icono === 'settings' && (
            <>
              <circle cx="12" cy="12" r="3" />
              <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
            </>
          )}
        </svg>
        <span>{enlace.label}</span>
      </a>
    ))}
  </nav>

  <div class="barra-lateral__footer">
    v1.0.0 — CONNECTED
  </div>
</aside>
